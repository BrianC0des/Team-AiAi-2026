# Server
PORT=3000

# Google Gemini — get your API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_google_studio_api_key_here"

# Google Cloud (Vertex AI) — only required when deploying to GCP / Vertex AI
# Leave blank for local dev using Google AI Studio key above
GCP_PROJECT_ID="your_google_cloud_project_id_here"
GCP_LOCATION="us-central1"

# Firebase Admin SDK — paste the full escaped JSON of your service account key
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Escape the JSON to a single line string before pasting (or use a tool like jq -c)
FIREBASE_SERVICE_ACCOUNT_JSON="your_escaped_service_account_json_here"
